# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (used for metadata, canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Admin auth (set strong passwords in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Supplier mode: mock | live | hybrid
# mock: use only mock supplier data
# live: use live supplier adapters only
# hybrid: use live when configured, fallback to mock
SUPPLIER_MODE=mock

# Supplier A (Dinamik Oto)
SUPPLIER_A_ENABLED=false
SUPPLIER_A_BASE_URL=https://supplier-a.example.com
SUPPLIER_A_API_KEY=your-supplier-a-api-key
SUPPLIER_A_SECRET_KEY=your-supplier-a-secret-key
SUPPLIER_A_TIMEOUT_MS=8000
# Proxy for Supplier A API requests (if required for IP whitelisting)
# For local testing: SUPPLIER_A_USE_PROXY=true, SUPPLIER_A_PROXY_URL=http://your-proxy-host:port
# For production: SUPPLIER_A_USE_PROXY=false, SUPPLIER_A_PROXY_URL=
SUPPLIER_A_USE_PROXY=false
SUPPLIER_A_PROXY_URL=
# Extra CA certificates for servers with incomplete chains (e.g., Dinamik Oto)
# For local testing: NODE_EXTRA_CA_CERTS=/app/certs/sectigo-intermediate.pem
# For Contabo production: leave empty
# NODE_EXTRA_CA_CERTS=

# Supplier B
SUPPLIER_B_API_KEY=
SUPPLIER_B_BASE_URL=

# Supplier C
SUPPLIER_C_API_KEY=
SUPPLIER_C_BASE_URL=

# Search cache (v0.2.0 simple in-memory TTL cache; Redis can be added later)
SEARCH_CACHE_TTL_SECONDS=60

# Search rate limiting (v0.2.0 in-memory per-IP rate limiter)
SEARCH_RATE_LIMIT_WINDOW_SECONDS=60
SEARCH_RATE_LIMIT_MAX=30

# Existing Supabase Catalog DB (v0.3.0)
# DATABASE_URL uses Supabase Shared Connection Pooler (pgbouncer)
# DIRECT_URL uses direct/shared pooler connection for schema inspection
# Never commit real values — these must only exist in local .env or server environment
DATABASE_URL=
DIRECT_URL=
USE_EXISTING_CATALOG_DB=false
CATALOG_SEARCH_SOURCE=mock
SUPPLIER_CATALOG_TABLE=supplier_products
SUPPLIER_DB_SCHEMA=public
SEARCH_LIVE_FALLBACK_ENABLED=false